{
  "name": "ncm-cli-player",
  "version": "1.0.0",
  "description": "基于 neteasecloudmusicapienhanced/api-enhanced 的交互式 CLI 点歌工具",
  "type": "module",
  "bin": {
    "ncm": "./bin/ncm.js"
  },
  "files": [
    "assets/",
    "bin/",
    "native/smtc-bridge/",
    "scripts/",
    "src/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "postinstall": "node ./scripts/build-smtc.js",
    "build:smtc": "node ./scripts/build-smtc.js --required --force",
    "build:smtc:all": "node ./scripts/build-smtc.js --required --force --all",
    "start": "node ./bin/ncm.js",
    "test": "node --test",
    "test:live": "node ./scripts/live-api.js"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "jimp": "^1.6.1",
    "qrcode-terminal": "^0.12.0",
    "string-width": "^7.2.0",
    "supports-terminal-graphics": "^0.1.0",
    "terminal-image": "^5.0.1"
  }
}
